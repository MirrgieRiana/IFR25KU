{
  "permissions": {
    "allow": [
      "Bash(site/scripts/convert-to-webp.sh *)"
    ]
  },
  "extraKnownMarketplaces": {
    "local": {
      "source": {
        "source": "directory",
        "path": "site/ifr25ku-site-claude-marketplace"
      }
    }
  },
  "enabledPlugins": {
    "ifr25ku-site@local": true
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "printf '{\"hookSpecificOutput\":{\"hookEventName\":\"PostToolUse\",\"additionalContext\":\"ぴょこっ🌱♪ 今の時刻は %s なのだぁ✨♪\"}}' \"$(date -Is)\""
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "printf '{\"hookSpecificOutput\":{\"hookEventName\":\"PostToolUseFailure\",\"additionalContext\":\"ぴょこっ🌱♪ 今の時刻は %s なのだぁ✨♪\"}}' \"$(date -Is)\""
          }
        ]
      }
    ]
  }
}
