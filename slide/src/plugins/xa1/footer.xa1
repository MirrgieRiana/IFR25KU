# footer: 各スライド下部のフッター（スタイルはCSS側。HTMLは構造だけ）
@USE("global")

templates.footer = (n -> %>
  <div class="footer">
    <div class="foot-left"><%= templates.tex("fairy_face"; 40) %><span>IFR25KU アップデートけいかく</span></div>
    <div class="foot-right"><%= templates.emo("seedling"; 26) %><span class="cf">Claude Fairy がつくったのだぁ</span><span class="pg"><%= n %> / 4</span></div>
  </div>
<%)

cssLines::push << %>
  /* ---- フッター（最小24px・Claude Fairy表記は右ぞろえ） ---- */
  .footer {
    position: absolute; left: 0; right: 0; bottom: 0; height: 54px; z-index: 2;
    background: rgba(255,255,255,.55);
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 36px 0 16px;
  }
  .foot-left, .foot-right { display: flex; align-items: center; gap: 12px; }
  .footer span { font-size: var(--min); font-weight: 800; color: var(--inkSoft); }
  .footer .cf { font-weight: 700; }
  .footer .pg { font-weight: 900; color: var(--accent); }
<%
