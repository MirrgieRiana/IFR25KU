# subtext: 中央ぞろえの説明文
@USE("global")

templates.sub = (lines -> %><div class="sub"><%= lines() | l => %><div><%= esc(l) %></div><% %></div><%)

cssLines::push << %>
  /* ---- 中央ぞろえの説明文 ---- */
  .sub { text-align: center; margin-top: 14px; color: var(--purpleD); }
  .sub div { font-size: 28px; font-weight: 800; line-height: 1.42; }
<%
